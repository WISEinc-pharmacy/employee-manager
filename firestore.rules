rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user has a specific role
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isEditorOrAdmin() {
      return isAuthenticated() && getUserRole() in ['admin', 'editor'];
    }

    // employees collection
    match /employees/{employeeId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isEditorOrAdmin();
    }

    // users collection (role management)
    match /users/{userEmail} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // governance collection (情報セキュリティ・ガバナンス台帳) — 管理者のみ
    match /governance/{docId} {
      allow read, write: if isAdmin();
    }

    // sync_reports (freee/KOT夜間同期の突合レポート) — 閲覧editor以上・書き込みはAdmin SDKバッチのみ
    match /sync_reports/{docId} {
      allow read: if isEditorOrAdmin();
      allow write: if false;
    }
  }
}
