rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user has a specific role
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isEditorOrAdmin() {
      return isAuthenticated() && getUserRole() in ['admin', 'editor'];
    }

    // employees collection
    match /employees/{employeeId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isEditorOrAdmin();
    }

    // users collection (role management)
    match /users/{userEmail} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // governance collection (情報セキュリティ・ガバナンス台帳) — 管理者のみ
    match /governance/{docId} {
      allow read, write: if isAdmin();
    }

    // sync_reports (freee/KOT夜間同期の突合レポート) — 閲覧editor以上・書き込みはAdmin SDKバッチのみ
    match /sync_reports/{docId} {
      allow read: if isEditorOrAdmin();
      allow write: if false;
    }

    // employeeIntake (新入社員受付フォーム) — 無認証でのcreate可・read/update/deleteはeditor以上
    // create時は許可キーのみ・必須フィールドのバリデーションでスパム書込を抑制
    match /employeeIntake/{docId} {
      allow read, update, delete: if isEditorOrAdmin();
      allow create: if isValidIntake(request.resource.data);
    }

    function isValidIntake(d) {
      return d.keys().hasOnly([
          'name','kana','emailPersonal','jobType','store','position',
          'hireDate','conversionPlannedType','trialPeriod',
          'careerUp','careerUpDate',
          'celebrationMoney','celebrationMoneyCondition',
          'submittedBy','note','status','source','submittedAt'
        ])
        && d.status == 'pending'
        && d.source == 'intake_form'
        && d.name is string && d.name.size() > 0 && d.name.size() < 100
        && d.emailPersonal is string && d.emailPersonal.size() > 0 && d.emailPersonal.size() < 300
        && d.store is string && d.store.size() > 0 && d.store.size() < 100
        && d.hireDate is string && d.hireDate.size() > 0 && d.hireDate.size() < 20
        && d.submittedBy is string && d.submittedBy.size() > 0 && d.submittedBy.size() < 100;
    }
  }
}
